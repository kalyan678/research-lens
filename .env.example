# DuckDB stores the analytical database in this local file.
DATABASE_PATH=data/research_lens.duckdb

# Get a free key from https://openalex.org/
OPENALEX_API_KEY=

# Local Ollama API used by: research-lens ask "..." --provider ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT_SECONDS=300
